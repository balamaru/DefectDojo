# CUSTOM FLOWABLES

class ColorBar(Flowable):
    """Horizontal colored bar used as section divider."""
    def __init__(self, width, height=4, color=C_ACCENT):
        super().__init__()
        self.bar_width  = width
        self.bar_height = height
        self.color      = color

    def draw(self):
        self.canv.setFillColor(self.color)
        self.canv.rect(0, 0, self.bar_width, self.bar_height, fill=1, stroke=0)

    def wrap(self, *args):
        return self.bar_width, self.bar_height


class SeverityBadge(Flowable):
    """Inline severity badge pill."""
    def __init__(self, text, sev="High"):
        super().__init__()
        self.text  = text
        self.color = SEV_COLOR_MAP.get(sev, C_INFO)
        self.w     = 70
        self.h     = 16

    def draw(self):
        self.canv.setFillColor(self.color)
        self.canv.roundRect(0, 0, self.w, self.h, 4, fill=1, stroke=0)
        self.canv.setFillColor(colors.white)
        self.canv.setFont("Helvetica-Bold", 8)
        self.canv.drawCentredString(self.w / 2, 4, self.text)

    def wrap(self, *args):
        return self.w, self.h


# STYLE FACTORY

