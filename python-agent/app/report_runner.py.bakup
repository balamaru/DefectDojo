    base = getSampleStyleSheet()

    def ps(name, **kw):
        return ParagraphStyle(name, **kw)

    return {
        "cover_title": ps("cover_title",
            fontSize=32, fontName="Helvetica-Bold",
            textColor=C_WHITE, alignment=TA_CENTER, leading=40),
        "cover_sub": ps("cover_sub",
            fontSize=14, fontName="Helvetica",
            textColor=colors.HexColor("#BDC3C7"), alignment=TA_CENTER, leading=20),
        "cover_meta": ps("cover_meta",
            fontSize=10, fontName="Helvetica",
            textColor=colors.HexColor("#95A5A6"), alignment=TA_CENTER),
        "h1": ps("h1",
            fontSize=16, fontName="Helvetica-Bold",
            textColor=C_ACCENT, spaceBefore=14, spaceAfter=6),
        "h2": ps("h2",
            fontSize=12, fontName="Helvetica-Bold",
            textColor=C_ACCENT2, spaceBefore=10, spaceAfter=4),
        "h3": ps("h3",
            fontSize=10, fontName="Helvetica-Bold",
            textColor=C_TEXT, spaceBefore=6, spaceAfter=2),
        "body": ps("body",
            fontSize=9, fontName="Helvetica",
            textColor=C_TEXT, leading=14),
        "body_small": ps("body_small",
            fontSize=8, fontName="Helvetica",
            textColor=C_TEXT, leading=12),
        "muted": ps("muted",
            fontSize=8, fontName="Helvetica",
